{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug API (cmd/server)",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/server",
      "env": {
        "DATABASE_URL": "postgres://energy:energy@db:5432/energy?sslmode=disable",
        "APP_ADDR": ":8080",
        "ALLOW_DEBUG_ENDPOINTS": "true",
        "SHUTDOWN_TIMEOUT": "10s"
      }
    }
  ]
}
